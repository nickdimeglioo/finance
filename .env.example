ASPNETCORE_ENVIRONMENT=Development
FINANCE_API_URL=http://localhost:8353
VITE_API_URL=http://localhost:8353/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5438
POSTGRES_DB=finance_tracker
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance-dev-password

ObjectStorage__Provider=Local
ObjectStorage__LocalRootPath=storage

# Keep these for switching ObjectStorage:Provider back to S3 later.
ObjectStorage__ServiceUrl=http://localhost:9000
ObjectStorage__Region=us-east-1
ObjectStorage__BucketName=finance-tracker
ObjectStorage__AccessKey=finance
ObjectStorage__SecretKey=finance-minio-password
